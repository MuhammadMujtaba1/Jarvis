# Groq API Key (get one at https://console.groq.com/keys)
# IMPORTANT: Never commit actual API keys to the repository
# Use this file as a template and add your real key locally only
VITE_GROQ_API_KEY=your_groq_api_key_here

# Groq model configuration
VITE_GROQ_MODEL=mixtral-8x7b-32768

# Voice/Audio settings
VITE_VOICE_ENABLED=true
VITE_VOICE_LANG=en-US
VITE_VOICE_GENDER=female

# Optional: call-with-ai-agent integration
VITE_ENABLE_VOICE_AGENT=true
